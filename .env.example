# Example environment configuration
# Copy this file to .env and replace the placeholders with your values.

MAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=orquetask.noreply@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_USE_TLS=true
MAIL_DEFAULT_SENDER=orquetask.noreply@gmail.com
SECRET_KEY=replace_with_your_secret_key
DATABASE_URI=postgresql+psycopg2://user:password@localhost:5432/your_db_name
